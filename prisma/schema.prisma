// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================
// CORE MODELS
// ============================================

model Tenant {
  id            String   @id @default(cuid())
  name          String   // School name
  slug          String   @unique // URL-safe identifier
  domain        String?  @unique // Custom domain if any
  
  contactEmail  String
  contactPhone  String?
  address       String?
  logo          String?
  
  isActive      Boolean  @default(true)
  plan          String   @default("basic") // basic, premium, enterprise
  maxUsers      Int      @default(5)
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  // Relations
  users         User[]
  categories    Category[]
  products      Product[]
  sales         Sale[]
  purchases     Purchase[]
  suppliers     Supplier[]
  
  @@map("tenants")
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  password      String   // Hashed with bcrypt
  name          String
  role          Role     @default(STAFF)
  
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  isActive      Boolean  @default(true)
  lastLoginAt   DateTime?
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@index([tenantId])
  @@index([email])
  @@map("users")
}

enum Role {
  SUPER_ADMIN
  SCHOOL_ADMIN
  STAFF
}

// ============================================
// INVENTORY MODELS
// ============================================

model Category {
  id            String    @id @default(cuid())
  name          String
  description   String?
  
  tenantId      String
  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  products      Product[]
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("categories")
}

model Product {
  id              String   @id @default(cuid())
  
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  sku             String
  barcode         String
  name            String
  description     String?
  
  categoryId      String?
  category        Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  
  // School uniform specific fields
  class           String?   // e.g., "Grade 1", "Grade 10"
  size            String?   // e.g., "S", "M", "L", "XL", "28", "32"
  color           String?   // e.g., "White", "Navy Blue"
  gender          String?   // e.g., "Boys", "Girls", "Unisex"
  
  // Pricing
  purchasePrice   Decimal  @db.Decimal(10, 2)
  sellingPrice    Decimal  @db.Decimal(10, 2)
  mrp             Decimal? @db.Decimal(10, 2)
  
  // Stock
  stock           Int      @default(0)
  minStockLevel   Int      @default(10)
  
  // Status
  isActive        Boolean  @default(true)
  
  // Relations
  saleItems       SaleItem[]
  purchaseItems   PurchaseItem[]
  inventoryLogs   InventoryLog[]
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@unique([tenantId, barcode])
  @@unique([tenantId, sku])
  @@index([tenantId])
  @@index([barcode])
  @@index([categoryId])
  @@map("products")
}

// ============================================
// SALES MODELS
// ============================================

model Sale {
  id              String   @id @default(cuid())
  billNo          String
  billDate        DateTime @default(now())
  
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  // Customer details
  customerName    String   @default("Cash Account")
  customerClass   String?
  customerMobile  String?
  
  // Payment
  paymentMode     PaymentMode @default(CASH)
  
  // Totals
  subtotal        Decimal  @db.Decimal(10, 2)
  discountPercent Decimal  @default(0) @db.Decimal(5, 2)
  discountAmount  Decimal  @default(0) @db.Decimal(10, 2)
  totalAmount     Decimal  @db.Decimal(10, 2)
  
  // Return handling
  isReturn        Boolean  @default(false)
  returnSaleId    String?
  returnSale      Sale?    @relation("SaleReturns", fields: [returnSaleId], references: [id], onDelete: SetNull)
  returns         Sale[]   @relation("SaleReturns")
  
  // Metadata
  createdBy       String   // User ID
  notes           String?
  
  items           SaleItem[]
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@unique([tenantId, billNo])
  @@index([tenantId])
  @@index([billDate])
  @@index([createdBy])
  @@map("sales")
}

model SaleItem {
  id              String   @id @default(cuid())
  
  saleId          String
  sale            Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  
  productId       String
  product         Product  @relation(fields: [productId], references: [id])
  
  // Snapshot product details at time of sale
  productName     String
  productBarcode  String
  
  quantity        Int
  rate            Decimal  @db.Decimal(10, 2)
  discountPercent Decimal  @default(0) @db.Decimal(5, 2)
  discountAmount  Decimal  @default(0) @db.Decimal(10, 2)
  amount          Decimal  @db.Decimal(10, 2)
  
  createdAt       DateTime @default(now())
  
  @@index([saleId])
  @@index([productId])
  @@map("sale_items")
}

enum PaymentMode {
  CASH
  CARD
  UPI
  BANK_TRANSFER
}

// ============================================
// PURCHASE MODELS
// ============================================

model Supplier {
  id              String   @id @default(cuid())
  
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  name            String
  contactPerson   String?
  email           String?
  phone           String?
  address         String?
  
  isActive        Boolean  @default(true)
  
  purchases       Purchase[]
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([tenantId])
  @@map("suppliers")
}

model Purchase {
  id              String   @id @default(cuid())
  voucherNo       String
  purchaseDate    DateTime @default(now())
  
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  supplierId      String
  supplier        Supplier @relation(fields: [supplierId], references: [id])
  
  totalAmount     Decimal  @db.Decimal(10, 2)
  notes           String?
  
  items           PurchaseItem[]
  
  createdBy       String   // User ID
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@unique([tenantId, voucherNo])
  @@index([tenantId])
  @@index([purchaseDate])
  @@index([supplierId])
  @@map("purchases")
}

model PurchaseItem {
  id              String   @id @default(cuid())
  
  purchaseId      String
  purchase        Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  
  productId       String
  product         Product  @relation(fields: [productId], references: [id])
  
  quantity        Int
  rate            Decimal  @db.Decimal(10, 2)
  amount          Decimal  @db.Decimal(10, 2)
  
  createdAt       DateTime @default(now())
  
  @@index([purchaseId])
  @@index([productId])
  @@map("purchase_items")
}

// ============================================
// AUDIT & LOGS
// ============================================

model InventoryLog {
  id              String   @id @default(cuid())
  
  productId       String
  product         Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  type            InventoryLogType
  referenceId     String?  // Sale ID or Purchase ID
  referenceType   String?  // "sale" or "purchase"
  
  quantityBefore  Int
  quantityChange  Int      // Positive for increase, negative for decrease
  quantityAfter   Int
  
  remarks         String?
  createdBy       String   // User ID
  
  createdAt       DateTime @default(now())
  
  @@index([productId])
  @@index([type])
  @@index([createdAt])
  @@map("inventory_logs")
}

enum InventoryLogType {
  PURCHASE
  SALE
  RETURN
  ADJUSTMENT
}